# Environment Variables for ME_CORE_Backend_mar_spar

# Application Settings
ENVIRONMENT=production
PORT=8000
SECRET_KEY=your-secure-secret-key-here-change-this-in-production

# MongoDB Configuration
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# For local MongoDB: mongodb://localhost:27017/hivememory
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/hivememory?retryWrites=true&w=majority
MONGODB_DATABASE=hivememory

# Security & CORS
CORS_ORIGINS=["https://yourdomain.com", "https://app.yourdomain.com"]
ALLOWED_HOSTS=["*"]

# Agent Configuration
AGENT_MEMORY_PATH=/mnt/memory
AGENT_CONFIG_PATH=/app/agents
MAX_AGENTS=10

# WebSocket Configuration
WEBSOCKET_TIMEOUT=30
WEBSOCKET_MAX_CONNECTIONS=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# Performance Settings
WORKERS=1
WORKER_CONNECTIONS=1000
KEEPALIVE=5

# Fly.io Specific (automatically set by platform)
# FLY_APP_NAME=me-core-backend-mar-spar
# FLY_REGION=sjc
# FLY_PUBLIC_IP=<assigned-by-fly>